{
  "name": "defuse-newsletter",
  "version": "0.1.0",
  "private": true,
  "description": "Simple branded email service: collect subscribers in a Resend audience and blast feature announcements that link to the docs changelog.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "email:dev": "email dev --dir emails --port 3030",
    "send": "tsx scripts/send.tsx",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@react-email/components": "^0.0.31",
    "@react-email/render": "^1.0.5",
    "drizzle-orm": "^0.45.2",
    "next": "^15.1.6",
    "next-auth": "5.0.0-beta.31",
    "nodemailer": "^6.9.16",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "drizzle-kit": "^0.31.10",
    "react-email": "^3.0.7",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
