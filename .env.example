# ── Gmail sending ─────────────────────────────────────────────────────────
# Mail is sent through your own Gmail account over SMTP. No domain to verify.
# Turn on 2-Step Verification, then create an App Password at
# https://myaccount.google.com/apppasswords and paste it below.
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Display name on the From line, and optional reply-to.
MAIL_FROM_NAME="NEAR Intents"
MAIL_REPLY_TO=

# ── Database (Postgres) ─────────────────────────────────────────────────────
# Vercel Postgres injects POSTGRES_URL in production (the app reads it too).
# Locally, paste that connection string here as DATABASE_URL, then `pnpm db:push`.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# ── Recipient import (optional) ─────────────────────────────────────────────
# Used by the Import button once you wire up fetchEmailsFromApi() in
# src/lib/importSource.ts. Names are up to you; match them in that function.
# EMAIL_SOURCE_API_URL=https://your-api.example.com/contacts
# EMAIL_SOURCE_API_KEY=

# ── Auth (Google, @defuse.org only) ─────────────────────────────────────────
# Google OAuth client (Cloud Console → Credentials → OAuth client ID → Web).
# Redirect URIs: http://localhost:3000/api/auth/callback/google
#                https://<your-vercel-url>/api/auth/callback/google
AUTH_GOOGLE_ID=xxxxxxxx.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=GOCSPX-xxxxxxxx
# Session secret: generate with `openssl rand -base64 32`
AUTH_SECRET=

# ── App ───────────────────────────────────────────────────────────────────
# Public base URL of this app, used to build unsubscribe links.
NEXT_PUBLIC_APP_URL=http://localhost:3000
