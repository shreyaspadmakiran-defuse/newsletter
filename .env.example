# ── Resend ────────────────────────────────────────────────────────────────
# API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The audience (subscriber list) that signups are added to and broadcasts go to.
# Create one at https://resend.com/audiences and paste its ID here.
RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Verified sending identity. The domain must be verified in Resend
# (https://resend.com/domains). Use a subdomain like updates.near-intents.org.
RESEND_FROM="Defuse Updates <updates@updates.near-intents.org>"

# Where replies should go (optional; falls back to RESEND_FROM).
RESEND_REPLY_TO=hello@near-intents.org

# ── App ───────────────────────────────────────────────────────────────────
# Public base URL of this app (used for absolute links in emails / redirects).
NEXT_PUBLIC_APP_URL=http://localhost:3000
